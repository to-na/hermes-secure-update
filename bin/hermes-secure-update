#!/usr/bin/env bash
# hermes-secure-update — secure update wrapper for Hermes Agent
# Fetch → Verify → Review → Apply pipeline with human approval gate.
#
# Usage:
#   hermes-secure-update [OPTIONS]
#
# Options:
#   --dry-run       Fetch + verify + review only; do not apply
#   --tag TAG       Update to a specific tag instead of main HEAD
#   --auto          Skip approval prompt (for cron/gateway; respects risk threshold)
#   --config FILE   Use alternate config file
#   --verbose       Show full commit diff in review
#   --ai-model M    Model for AI security review (default: config or hermes default)
#   --no-ai-review  Skip AI security review
#   -h, --help      Show this help
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"
CONFIG_FILE="${HERMES_SECURE_UPDATE_CONFIG:-$SCRIPT_DIR/../config/default.conf}"

# ── Defaults (overridden by config) ──────────────────────────────────────────
HERMES_REPO="${HERMES_HOME:-$HOME/.hermes}/hermes-agent"
EXPECTED_REMOTE_PATTERN="github\.com[:/]NousResearch/hermes-agent(\.git)?$"
AUTO_APPROVE_BELOW="low"
BLOCK_ABOVE="high"
SHOW_DIFF="true"
PREFER_TAGS="false"
KNOWN_MAINTAINERS_FILE="$SCRIPT_DIR/../config/maintainers.txt"
# AI review: model to use (empty = hermes default) and enable flag
AI_REVIEW_MODEL=""
AI_REVIEW_ENABLED="true"
AI_REVIEW_MAX_DIFF_CHARS="12000"
# When AI flags the diff as suspicious, block --auto and require explicit human yes
AI_BLOCK_ON_SUSPICIOUS="true"

# ── Parse args ───────────────────────────────────────────────────────────────
DRY_RUN=false
TARGET_TAG=""
AUTO_APPROVE=false
VERBOSE=false
AI_REVIEW_OVERRIDE=""   # "" = use config; "off" = --no-ai-review

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)      DRY_RUN=true; shift ;;
    --tag)          TARGET_TAG="$2"; shift 2 ;;
    --auto)         AUTO_APPROVE=true; shift ;;
    --config)       CONFIG_FILE="$2"; shift 2 ;;
    --verbose)      VERBOSE=true; shift ;;
    --ai-model)     AI_REVIEW_MODEL="$2"; shift 2 ;;
    --no-ai-review) AI_REVIEW_OVERRIDE="off"; shift ;;
    -h|--help)
      sed -n '2,/^set -euo/p' "$0" | grep '^#' | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# ── Load config ──────────────────────────────────────────────────────────────
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

# ── Source library modules ───────────────────────────────────────────────────
source "$LIB_DIR/common.sh"
source "$LIB_DIR/verify_remote.sh"
source "$LIB_DIR/verify_signatures.sh"
source "$LIB_DIR/risk_score.sh"
source "$LIB_DIR/diff_summary.sh"
source "$LIB_DIR/ai_review.sh"

# Resolve effective AI review enablement (CLI flag overrides config)
ai_review_active() {
  if [[ "$AI_REVIEW_OVERRIDE" == "off" ]]; then
    return 1
  fi
  [[ "$AI_REVIEW_ENABLED" == "true" ]]
}

# ── Main pipeline ────────────────────────────────────────────────────────────
main() {
  info "hermes-secure-update"
  echo ""

  # Phase 1: FETCH (read-only)
  phase "1/5  FETCH"
  do_fetch
  echo ""

  # Phase 2: VERIFY
  phase "2/5  VERIFY"
  do_verify
  echo ""

  # Phase 3: AI REVIEW
  phase "3/5  AI REVIEW"
  do_ai_review
  echo ""

  # Phase 4: REVIEW
  phase "4/5  REVIEW"
  do_review
  echo ""

  # Phase 5: APPLY
  if $DRY_RUN; then
    info "Dry run — skipping apply."
    exit 0
  fi

  phase "5/5  APPLY"
  do_apply
}

# ── Phase 1: Fetch ───────────────────────────────────────────────────────────
do_fetch() {
  if [[ ! -d "$HERMES_REPO/.git" ]]; then
    fail "Not a git repository: $HERMES_REPO"
    exit 1
  fi

  # L1: Remote URL verification
  verify_remote "$HERMES_REPO" "$EXPECTED_REMOTE_PATTERN"

  info "Fetching from origin..."
  if [[ -n "$TARGET_TAG" ]]; then
    git -C "$HERMES_REPO" fetch origin --tags --quiet 2>/dev/null || true
    if ! git -C "$HERMES_REPO" rev-parse "$TARGET_TAG" &>/dev/null; then
      fail "Tag '$TARGET_TAG' not found."
      exit 1
    fi
    TARGET_REF="$TARGET_TAG"
  else
    git -C "$HERMES_REPO" fetch origin main --quiet
    TARGET_REF="origin/main"
  fi

  BEHIND=$(git -C "$HERMES_REPO" rev-list HEAD.."$TARGET_REF" --count 2>/dev/null || echo 0)
  if [[ "$BEHIND" -eq 0 ]]; then
    ok "Already up to date."
    exit 0
  fi

  info "$BEHIND new commit(s) available."
}

# ── Phase 2: Verify ──────────────────────────────────────────────────────────
do_verify() {
  # L2: Commit signature verification
  verify_signatures "$HERMES_REPO" "$TARGET_REF" "$KNOWN_MAINTAINERS_FILE"

  # L3: Tag signature (if updating to a tag)
  if [[ -n "$TARGET_TAG" ]]; then
    verify_tag_signature "$HERMES_REPO" "$TARGET_TAG"
  fi

  # L4: Risk scoring
  compute_risk "$HERMES_REPO" "$TARGET_REF"
}

# ── Phase 3: AI Review ───────────────────────────────────────────────────────
do_ai_review() {
  if ! ai_review_active; then
    info "AI review disabled (--no-ai-review or config)."
    _AI_REVIEW_RESULT="skipped"
    return 0
  fi

  ai_review "$HERMES_REPO" "$TARGET_REF" "$AI_REVIEW_MODEL" "$AI_REVIEW_MAX_DIFF_CHARS"

  # Surface the verdict for the approval gate
  local verdict
  verdict=$(ai_review_verdict)
  case "$verdict" in
    suspicious)
      fail "AI flagged this diff as SUSPICIOUS."
      ;;
    review_needed)
      warn "AI recommends REVIEW NEEDED for this diff."
      ;;
    clean)
      ok "AI review: no security concerns."
      ;;
    *)
      info "AI review: no verdict available."
      ;;
  esac
}

# ── Phase 4: Review ──────────────────────────────────────────────────────────
do_review() {
  show_diff_summary "$HERMES_REPO" "$TARGET_REF" "$VERBOSE"

  echo ""
  echo "── Risk: $(risk_label) ──"

  # AI verdict (empty/unknown/skipped when AI review is off)
  local ai_verdict
  ai_verdict=$(ai_review_verdict)
  local ai_suspicious=false
  if [[ "$ai_verdict" == "suspicious" && "$AI_BLOCK_ON_SUSPICIOUS" == "true" ]]; then
    ai_suspicious=true
  fi

  # Auto-approve logic
  if $AUTO_APPROVE; then
    # AI suspicious always blocks --auto (no unattended apply of flagged diffs)
    if $ai_suspicious; then
      fail "AI flagged diff as SUSPICIOUS — refusing unattended apply."
      fail "Run interactively to review: hermes-secure-update"
      exit 1
    fi

    local risk_level
    risk_level=$(risk_level_numeric)
    local threshold
    threshold=$(risk_to_numeric "$AUTO_APPROVE_BELOW")
    local block
    block=$(risk_to_numeric "$BLOCK_ABOVE")

    if [[ "$risk_level" -gt "$block" ]]; then
      fail "Risk level $(risk_label) exceeds block threshold ($BLOCK_ABOVE). Aborting."
      exit 1
    fi
    if [[ "$risk_level" -le "$threshold" ]]; then
      ok "Auto-approved (risk $(risk_label) ≤ $AUTO_APPROVE_BELOW)."
      return 0
    fi
    fail "Risk $(risk_label) > auto-approve threshold ($AUTO_APPROVE_BELOW). Needs manual approval."
    exit 1
  fi

  # Interactive approval (skip in dry-run)
  if $DRY_RUN; then
    info "Dry run — skipping approval prompt."
    return 0
  fi

  echo ""
  if $ai_suspicious; then
    warn "AI flagged this diff as SUSPICIOUS. Review the AI output above carefully."
    read -rp "Apply ANYWAY despite AI warning? [y/N] " -n 1 reply
  else
    read -rp "Apply this update? [y/N] " -n 1 reply
  fi
  echo ""
  if [[ ! "$reply" =~ ^[Yy]$ ]]; then
    info "Aborted."
    exit 0
  fi
}

# ── Phase 4: Apply ───────────────────────────────────────────────────────────
do_apply() {
  info "Applying update via hermes update..."
  echo ""

  if [[ -n "$TARGET_TAG" ]]; then
    # Tag-pinned update: checkout tag, then let hermes update handle deps
    git -C "$HERMES_REPO" checkout "$TARGET_TAG" --quiet
    info "Checked out tag $TARGET_TAG. Running dependency sync..."
    # hermes update will detect the checkout and sync deps
    hermes update --yes
  else
    hermes update --yes
  fi

  echo ""
  ok "Update complete."
}

main
